model:
  target_col: target
  test_size: 0.2
  random_state: 42
  model_type: lightgbm
  params:
    n_estimators: 300
    learning_rate: 0.05
    max_depth: -1
    num_leaves: 31
backtest:
  train_years: 5.0
  test_years: 1.0
  step_years: 1.0
  rebalance_freq: MS
  top_n: 10
  top_pct: 0.1
  min_stocks: 5
  transaction_cost: 0.001
  start_date: null
  end_date: null
data:
  price_data_path: data/prices.csv
  fundamental_data_path: data/fundamentals.csv
  benchmark_data_path: data/benchmark.csv
  universe_path: data/universe.txt
  sentiment_news_path: data/news.csv
  output_dir: output
  models_dir: models
features:
  return_periods:
  - 21
  - 63
  - 126
  - 252
  volatility_windows:
  - 20
  - 60
  volume_window: 20
  include_fundamentals: true
  horizon_days: 63
  use_sentiment: false
  sentiment_source: news
  sentiment_lookbacks:
  - 1
  - 7
  - 14
  sentiment_min_count: 1
  sentiment_fillna: 0.0
sentiment:
  news_data_path: null
  model_type: lexicon
  text_column: headline
  market_close_hour: 16
  timezone: null
  lookbacks:
  - 1
  - 7
  - 14
  min_daily_count: 1
  include_volume_features: true
  include_trend_features: true
  fillna_value: 0.0
cli:
  output_format: table
  verbose: true
  save_results: true
  results_path: null
analysis:
  weights:
    model_score: 0.49310213976812456
    value_score: 0.19676009976294476
    quality_score: 0.3101377604689307
  filters:
    min_roe: 0.03
    min_net_margin: 0.02
    max_debt_to_equity: 1.8
    min_market_cap: null
    min_avg_volume: null
  vertical:
    top_k_per_sector: 8
    export_candidates: true
  horizontal:
    portfolio_size: 10
    max_position_weight: 0.15
    min_position_weight: 0.02
    max_sector_weight: 0.3
    target_max_drawdown: 0.2
    target_volatility: 0.25
    min_diversification: 0.7
    selection_method: heuristic
    max_combinations: 1000
